{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcav.io/schemas/input_payload_scheduling_compat_v1.schema.json",
  "title": "InputPayloadSchedulingCompatV1",
  "description": "Input payload schema for SCHEDULING_COMPAT_V1 contract. Per-agent scheduling data.",
  "type": "object",
  "properties": {
    "timezone": {
      "type": "string",
      "description": "UTC offset string used by the scheduling oracle (e.g. UTC, UTC-5, UTC+1, UTC+5:30)",
      "maxLength": 64
    },
    "availability_windows": {
      "type": "array",
      "description": "Available time windows (max 7). Use start/end = NONE to mark no availability entry.",
      "maxItems": 7,
      "items": {
        "type": "object",
        "properties": {
          "day": {
            "type": "string",
            "enum": [
              "MON",
              "TUE",
              "WED",
              "THU",
              "FRI"
            ]
          },
          "start": {
            "type": "string",
            "description": "Start time in HH:MM format, or NONE"
          },
          "end": {
            "type": "string",
            "description": "End time in HH:MM format, or NONE"
          }
        },
        "required": ["day", "start", "end"],
        "additionalProperties": false
      }
    },
    "min_duration_minutes": {
      "type": "integer",
      "description": "Minimum required overlap duration in minutes",
      "minimum": 1
    },
    "location_constraint": {
      "type": "string",
      "description": "Location modality preference",
      "enum": [
        "EITHER",
        "REMOTE_ONLY",
        "IN_PERSON_ONLY"
      ]
    }
  },
  "required": [
    "timezone",
    "availability_windows",
    "min_duration_minutes",
    "location_constraint"
  ],
  "additionalProperties": false
}
