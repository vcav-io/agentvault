{
  "name": "agentvault-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for AgentVault relay — bilateral bounded signals between AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tool-registry.js",
      "types": "./dist/tool-registry.d.ts"
    }
  },
  "bin": {
    "agentvault-mcp-server": "dist/index.js"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vcav-io/agentvault"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.8.0",
    "agentvault-client": "file:../agentvault-client",
    "json-canonicalize": "^2.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.22.0",
    "vitest": "^1.6.1"
  }
}
