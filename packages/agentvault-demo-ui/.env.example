# AgentVault Demo UI — Environment Configuration
#
# Copy this file to .env and fill in your API key.
#
# PROVIDER selects the LLM backend. Required.
#   anthropic — uses Anthropic Messages API (requires ANTHROPIC_API_KEY)
#   openai    — uses OpenAI Chat Completions API (requires OPENAI_API_KEY)

PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# — or —
# PROVIDER=openai
# OPENAI_API_KEY=sk-...

# AFAL peer-to-peer ports (each agent listens on its own port)
# BOB_AFAL_PORT=3201
# ALICE_AFAL_PORT=3202
