{
  "policy_version": "1",
  "policy_id": "compatibility_safe_v1",
  "policy_scope": "RELAY_GLOBAL",
  "model_profile_allowlist": ["api-claude-sonnet-v1"],
  "provider_allowlist": ["anthropic", "openai"],
  "max_output_tokens": null,
  "rules": [
    {
      "rule_id": "no_digits",
      "type": "unicode_category_reject",
      "value": "Nd",
      "scope": { "kind": "all_string_values", "skip_keys": ["schema_version"] },
      "classification": "GATE"
    },
    {
      "rule_id": "no_currency_symbols",
      "type": "unicode_category_reject",
      "value": "Sc",
      "scope": { "kind": "all_string_values", "skip_keys": ["schema_version"] },
      "classification": "GATE"
    }
  ],
  "entropy_constraints": {
    "budget_bits": 32,
    "classification": "ADVISORY",
    "review_trigger_pct": 80
  }
}
